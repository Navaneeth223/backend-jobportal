# ════════════════════════════════════════════════════════════════
#  FRONTEND  (React / Vite)
# ════════════════════════════════════════════════════════════════

logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# ════════════════════════════════════════════════════════════════
#  BACKEND  (Django / Python)
# ════════════════════════════════════════════════════════════════

# Virtual environment — NEVER upload this
src/server/venv/
src/server/env/
src/server/.venv/
venv/
env/
.venv/

# Environment variables — contains secrets, NEVER upload
.env
.env.local
.env.production
.env.development
*.env

# Django cache & compiled files
__pycache__/
*.py[cod]
*.pyo
*.pyc

# Django default database
db.sqlite3
*.sqlite3

# Django media & static files (user uploads, collected static)
src/server/media/
src/server/staticfiles/
src/server/static_root/
media/
staticfiles/

# ════════════════════════════════════════════════════════════════
#  EDITOR & OS FILES
# ════════════════════════════════════════════════════════════════

.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

